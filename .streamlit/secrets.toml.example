# ── secrets.toml — copy this file to secrets.toml and fill in your keys ──────
# secrets.toml is gitignored and must never be committed.
# Render deployment: add each key as an Environment Variable in the Render
# dashboard (Settings > Environment), NOT as a Secret File — env vars survive
# restarts cleanly on the ephemeral Render filesystem.

[keys]
# FRED macroeconomic data (free, required for Macro Dashboard)
# Get key at: https://fred.stlouisfed.org/docs/api/api_key.html
fred_api_key = ""

# AI agents — provide at least one (Anthropic preferred; OpenAI is fallback)
# Anthropic: https://console.anthropic.com/
anthropic_api_key = ""
# OpenAI: https://platform.openai.com/api-keys
openai_api_key = ""

# Financial Datasets API (optional — additional price data)
financial_datasets_key = ""

# PortWatch override (optional — default public endpoint used if blank)
portwatch_endpoint = ""
portwatch_token    = ""

[lseg]
# LSEG / Refinitiv Eikon data (optional — yfinance is the fallback)
# Requires Eikon or LSEG Workspace running on the same machine.
# Key: https://developers.lseg.com → My Apps → Create App Key
app_key = ""

[config]
# Feature flags
enable_auth      = false   # set true to require password on app load
enable_rss       = true    # live geo RSS ingestion
refresh_interval = 300     # seconds between Overview auto-refresh

[auth]
# Only used when enable_auth = true above
password = ""
